# ─────────────────────────────────────────────────────────────
# EIPP — Environment configuration
# Copy to .env.local and fill. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────

# Master switch. Without this, every connector returns [] and the app
# uses the editorial mock dataset only. Set to "live" to enable real APIs.
EIPP_DATA_MODE=mock

# ── News sources (Tier 3 verification) ───────────────────────
# Google News RSS is public — no key required. This var is reserved for
# a future SerpAPI / Google News JSON upgrade.
# GOOGLE_NEWS_API_KEY=

# NewsAPI.org — https://newsapi.org
# Free tier: 100 requests/day, developer use only. Tier 3 signal.
# NEWS_API_KEY=

# ── Ticketing / marketplace (Tier 2 verification) ────────────
# Ticketmaster Discovery — https://developer.ticketmaster.com
# Free tier: 5000 calls/day. Structured event data with venue + pricing.
# TICKETMASTER_API_KEY=

# ── Claude AI (narrative generation layer) ───────────────────
# Used by /api/ai/{concepts,explain,summary,trends}.
# When unset, endpoints return deterministic fallback payloads —
# the app never breaks because of missing AI infrastructure.
# Model: claude-haiku-4-5 (configured in lib/ai/claude.ts)
# Pricing: ~$1/M input, ~$5/M output · prompt caching gives 90% discount
#          on the shared system prompt after first call.
# ANTHROPIC_API_KEY=
